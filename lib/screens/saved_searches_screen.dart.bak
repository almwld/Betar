          final s = _saved[i];
          return Card(
            margin: const EdgeInsets.only(bottom: 12),
            child: ListTile(
              leading: const Icon(Icons.search, color: AppTheme.goldColor),
              title: Text(s['query']),
              subtitle: Text('${s['filters']} أکآ·أ‚آ£أکآ¢أ‚آ¢أکآ·أ‚آ¢أƒآ¢أ¢آ€آڑأ‚آ¬أکآ·أ‚آ¢أکآ¢أ‚آ¢ ${s['date']}'),
              trailing: IconButton(
                icon: const Icon(Icons.delete, color: Colors.red),
                onPressed: () {},
              ),
              onTap: () {},
            ),
          );
        },
      ),
    );
  }
}