              style: const TextStyle(fontFamily: 'Changa'),
            ),
            backgroundColor: AppTheme.error,
          ),
        );
      }
    } finally {
      if (mounted) {
        setState(() => _isLoading = false);
      }
    }
  }

  void _loginAsGuest() {
    setState(() => _isGuest = true);
    Navigator.pushReplacementNamed(context, '/main');
  }

